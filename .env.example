DEVICE=cpu
MAX_UPLOAD_MB=500
MAX_DURATION_HOURS=4
DEFAULT_PRESET=balanced
DEFAULT_LANGUAGE=ru
RATE_LIMIT_PER_HOUR=30
QUEUE_MAX_SIZE=5
ASYNC_THRESHOLD_SECONDS=900

DATABASE_URL=postgresql+asyncpg://transcribe:transcribe@localhost:5432/transcribe
DB_PASSWORD=transcribe

# Bot — polling locally, webhook on VPS
BOT_TOKEN=
WEBHOOK_URL=
WEBHOOK_PATH=/bot/webhook
BOT_HOST=0.0.0.0
BOT_PORT=8081
API_URL=http://localhost:8000
